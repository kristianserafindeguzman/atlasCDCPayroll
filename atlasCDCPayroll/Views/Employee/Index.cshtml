@model IEnumerable<atlasCDCPayroll.Models.Employee>
@using Microsoft.AspNetCore.Http
@{
    Layout = "_Layout";
    var role = Context.Session.GetString("UserRole");
}
<div class="card p-4 border-0 shadow-sm" style="border-radius: 15px; background-color: white;">
    <h2 class="fw-bold mb-1" style="color: #2b7a37;">@(role == "Admin" ? "Employee Management" : "Employee Directory")</h2>

    @if (role == "Admin")
    {
        <a asp-controller="Employee" asp-action="Create" class="text-warning fw-bold text-decoration-none d-block mb-3">Add New Employee</a>
    }
    @if (role == "Manager")
    {
        <p class="text-muted mb-3">View employee information and account details.</p>
    }

    <div class="mb-3 col-md-4">
        <input type="text" id="liveSearchBox" class="form-control" placeholder="Search by name or designation..." />
    </div>

    <table class="table table-striped table-hover align-middle" id="staffTable">
        <thead style="background-color: #2b7a37; color: white;">
            <tr>
                <th>Employee ID</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Designation</th>
                <th>Level</th>
                <th>Username</th>
                <th>Password</th>
                @if (role == "Admin")
                {
                    <th class="text-center">Action</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeID</td>
                    <td>@item.Name</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.Designation</td>
                    <td>@item.Level</td>
                    <td>@item.Username</td>
                    <td>@item.Password</td>
                    @if (role == "Admin")
                    {
                        <td class="text-center"><a asp-controller="Employee" asp-action="Delete" asp-route-id="@item.EmployeeID" class="text-dark" onclick="return confirm('Delete this record?');">Delete</a></td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    document.getElementById('liveSearchBox').addEventListener('keyup', function() {
        var term = this.value.toLowerCase();
        var dataRows = document.querySelectorAll('#staffTable tbody tr');
        dataRows.forEach(function(row) {
            var workerName = row.cells[1].textContent.toLowerCase();
            var jobTitle = row.cells[4].textContent.toLowerCase();
            row.style.display = (workerName.includes(term) || jobTitle.includes(term)) ? '' : 'none';
        });
    });
</script>