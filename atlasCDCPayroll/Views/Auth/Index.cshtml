@{
    Layout = "_Layout";
}
<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card p-5 shadow-sm border-0" style="width: 450px; border-radius: 20px; background-color: white;">
        <div class="text-center mb-4">
            <h1 class="fw-bold" style="color: #2b7a37; font-family: sans-serif;">ATLAS CDC</h1>
            <p class="text-warning fw-semibold m-0" style="font-size: 13px;">Payroll Management System</p>
        </div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="mb-3">
                <label class="form-label fw-semibold text-secondary mb-1" style="font-size: 14px;">Username</label>
                <input type="text" name="username" class="form-control py-2" required />
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold text-secondary mb-1" style="font-size: 14px;">Password</label>
                <input type="password" name="password" class="form-control py-2" required />
            </div>
            <button type="submit" class="btn text-white w-100 py-2 fw-semibold" style="background-color: #2b7a37; border-radius: 8px;">Sign In</button>
        </form>
    </div>
</div>