@model IEnumerable<atlasCDCPayroll.Models.Payslip>

@{
	ViewData["Title"] = "My Payslips";
}

<h2 style="color: #2E7D32; font-family: 'Segoe UI'; border-bottom: 2px solid #FF8F00; padding-bottom: 10px; margin-bottom: 20px;">
	My Payslips Dashboard
</h2>

<table class="table table-bordered table-striped" style="font-family: 'Segoe UI'; font-size: 14px;">
	<thead style="background-color: #2E7D32; color: white;">
		<tr>
			<th>Month / Year</th>
			<th>Generated On</th>
			<th>Basic Salary</th>
			<th>Net Salary</th>
			<th>Action</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td style="font-weight: bold;">@item.MonthName @item.Year</td>
				<td>@item.GeneratedOn.ToString("MMMM dd, yyyy")</td>
				<td>P @item.BasicSalary.ToString("N2")</td>
				<td style="color: #2E7D32; font-weight: bold;">P @item.NetSalary.ToString("N2")</td>
				<td>
					<a asp-action="Print" asp-route-id="@item.PayslipId" target="_blank" class="btn btn-sm btn-outline-success">Print Payslip</a>
				</td>
			</tr>
		}
	</tbody>
</table>