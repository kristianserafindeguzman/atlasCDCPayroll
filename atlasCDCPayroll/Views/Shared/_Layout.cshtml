<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Payroll Management System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/atlasCDCPayroll.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="top-header">
        <div>
            <div class="brand-title">ATLAS CDC</div>
            <div class="brand-subtitle">Payroll Management System</div>
        </div>
    </div>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="menu-panel">
            <ul class="menu-items">
                <li><a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">Home</a></li>

                @if (User.IsInRole("Administrator") || User.IsInRole("Manager"))
                {
                    <li><a asp-controller="Employees" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Employees" ? "active" : "")">Employees</a></li>
                }

                @if (User.IsInRole("Employee"))
                {
                    <li><a asp-controller="Payslips" asp-action="MyPayslips" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Payslips" ? "active" : "")">My Payslips</a></li>
                }

                <li><a asp-controller="Account" asp-action="Logout">Log Out</a></li>
            </ul>
            <div class="logged-in-as">Logged in as @User.Identity.Name</div>
        </div>
    }

    <div class="page-content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - ATLAS CDC Payroll System
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
