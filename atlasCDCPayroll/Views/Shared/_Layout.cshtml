@{
    Layout = null;
    var userRole = Context.Session.GetString("UserRole");
    var userName = Context.Session.GetString("Username");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ATLAS CDC Payroll System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body style="background-color: #f8f9fa;">

    <div style="background: linear-gradient(to right, #4c7e2b 0%, #4c7e2b 50%, #ff9900 100%); padding: 20px; color: white;">
        <h2 class="m-0 fw-bold" style="font-family: sans-serif;">ATLAS CDC</h2>
        <p class="m-0" style="font-size: 14px;">Payroll Management System</p>
    </div>

    <div class="container mt-3">
        @if (!string.IsNullOrEmpty(userRole))
        {
            <div class="p-2 mb-4 rounded" style="background-color: #2b7a37;">
                <ul class="nav">
                    <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Payroll" asp-action="Dashboard">Home</a></li>

                    @if (userRole == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Employee" asp-action="Index">Employees</a></li>
                    }
                    else if (userRole == "Manager")
                    {
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Employee" asp-action="Index">Employees</a></li>
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Payroll" asp-action="Messages">Messages</a></li>
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Payroll" asp-action="Payslips">Payslips</a></li>
                    }
                    else if (userRole == "Employee")
                    {
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Payroll" asp-action="Messages">Messages</a></li>
                        <li class="nav-item"><a class="nav-link text-white px-3" asp-controller="Payroll" asp-action="PersonalPayslips">Payslips</a></li>
                    }

                    <li class="nav-item ms-auto"><a class="nav-link text-white px-3" asp-controller="Auth" asp-action="Logout">Log Out</a></li>
                </ul>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>