@{
    Layout = "_Layout";
}
<div class="card p-5 border-0 shadow-sm" style="border-radius: 15px; background-color: white; max-width:600px;">
    <h2 class="fw-bold mb-4" style="color: #2b7a37;">Generate Payslip</h2>
    <form asp-controller="Payroll" asp-action="SavePayslip" method="post">
        <input type="hidden" name="employeeName" value="@ViewBag.EmployeeName" />
        <div class="row mb-3"><label class="col-sm-4 fw-bold">Employee</label><div class="col-sm-8 text-warning fw-bold">@ViewBag.EmployeeName</div></div>
        <div class="row mb-3"><label class="col-sm-4 fw-bold">Month & Year</label><div class="col-sm-4"><select name="month" class="form-select form-select-sm"><option value="May">May</option><option value="June">June</option></select></div><div class="col-sm-4"><select name="year" class="form-select form-select-sm"><option value="2026">2026</option></select></div></div>
        <div class="row mb-3"><label class="col-sm-4 fw-bold">Basic Salary</label><div class="col-sm-8"><input type="number" step="0.01" name="basicSalary" value="12000.00" class="form-control form-control-sm" /></div></div>
        <div class="row mb-3"><label class="col-sm-4 fw-bold">Number of Leaves</label><div class="col-sm-8"><input type="number" name="leaves" value="2" class="form-control form-control-sm" /></div></div>
        <button type="submit" class="btn text-white mt-3 px-4" style="background-color: #2b7a37;">Generate Payslip</button>
    </form>
</div>