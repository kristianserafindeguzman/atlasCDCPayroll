@using Microsoft.AspNetCore.Http
@{
    Layout = "_Layout";
    var role = Context.Session.GetString("UserRole");
    var name = Context.Session.GetString("Username");
}

<div class="card p-5 border-0 shadow-sm" style="border-radius: 15px; border-left: 5px solid #2b7a37 !important; background-color: white;">
    @if (role == "Employee")
    {
        <h1 class="fw-bold mb-3" style="color: #2b7a37; font-family: sans-serif;">
            Welcome, <span style="color: #ff9900;">@name!!</span>
        </h1>
        <p class="text-muted m-0" style="font-size: 15px;">Welcome to the ATLAS CDC Payroll System.</p>
        <p class="text-muted" style="font-size: 15px;">Use the navigation menu above to access your payroll information, payslips, messages, and employee services.</p>
    }
    else
    {
        <h1 class="fw-bold" style="color: #2b7a37;">@role Dashboard</h1>
        <h5 class="text-warning fw-bold mb-4">Welcome to @role Portal</h5>
        <p class="text-muted m-0" style="font-size: 15px;">Welcome to the ATLAS CDC Payroll Management System.</p>
        <p class="text-muted" style="font-size: 15px;">Use the navigation menu above to manage employee records, system information, and administrative operations.</p>
    }
</div>