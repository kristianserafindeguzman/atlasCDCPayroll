@{
    Layout = "_Layout";
}
<div class="card p-5 border-0 shadow-sm" style="border-radius: 15px; background-color: white;">
    <h2 class="fw-bold mb-4" style="color: #2b7a37;">Compose Message</h2>
    <form asp-controller="Payroll" asp-action="SendMessage" method="post">
        <div class="row mb-3"><label class="col-sm-2 fw-bold">To</label><div class="col-sm-4"><select name="receiverName" class="form-select rounded-0" required><option value="">---Select---</option>@foreach (var name in ViewBag.Employees) {
            <option value="@name">@name</option>
        }
    </select></div></div>
    <div class="row mb-4"><label class="col-sm-2 fw-bold">Message</label><div class="col-sm-10"><textarea name="messageText" class="form-control rounded-0" rows="6" required></textarea></div></div>
    <button type="submit" class="btn text-white float-end px-4" style="background-color: #2b7a37;">Send Message</button>
</form>
</div>